# ==============================================================================
#  Satark — Production Environment Variables
#  Copy this to deployment/.env.prod and fill in your values.
#  NEVER commit .env.prod to git — it is in .gitignore.
# ==============================================================================

# ── Google Cloud Project ──────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=asia-south1

# ── Cloud Run Service Names ───────────────────────────────────────────────────
BACKEND_SERVICE_NAME=satark-backend
FRONTEND_SERVICE_NAME=satark-frontend

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO

# ── AI Configuration ──────────────────────────────────────────────────────────
# GEMINI_API_KEY goes in Secret Manager (satark-gemini-api-key) NOT here
AI_MODEL=gemini-3-flash-preview

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=gcs
# GCS_BUCKET_NAME goes in Secret Manager (satark-gcs-bucket-name) NOT here

# ── Database (Cloud SQL) ──────────────────────────────────────────────────────
# Full connection string goes in Secret Manager (satark-database-url)
# Format: postgresql://USER:PASS@/DB_NAME?host=/cloudsql/PROJECT:REGION:INSTANCE
CLOUD_SQL_CONNECTION_NAME=your-project-id:asia-south1:satark-postgres
POSTGRES_DB=satark_db
POSTGRES_USER=satark_user

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT_SECRET_KEY goes in Secret Manager (satark-jwt-secret-key) NOT here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── URLs (set after first deploy, then update frontend build-arg) ─────────────
# After backend deploys, get its URL and set here:
BACKEND_SERVICE_URL=https://satark-backend-HASH-uc.a.run.app
FRONTEND_SERVICE_URL=https://satark-frontend-HASH-uc.a.run.app

# This goes in Secret Manager (satark-next-public-api-url):
NEXT_PUBLIC_API_URL=https://satark-backend-HASH-uc.a.run.app

# This goes in Secret Manager (satark-frontend-url):
FRONTEND_URL=https://satark-frontend-HASH-uc.a.run.app

# ── Image Config ──────────────────────────────────────────────────────────────
# Artifact Registry (not GCR)
IMAGE_TAG=latest
