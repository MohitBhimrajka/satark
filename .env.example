# ==============================================================================
#  Satark — Local Development Environment Variables
#  Copy this to .env and fill in your values.
#  NEVER commit .env to git.
# ==============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG

# ── Database (local Docker PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgresql://satark_user:satark_pass@localhost:5432/satark_db
POSTGRES_USER=satark_user
POSTGRES_PASSWORD=satark_pass
POSTGRES_DB=satark_db

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
AI_MODEL=gemini-3-flash-preview

# ── Storage (use "local" for dev, "gcs" for production) ──────────────────────
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=/app/uploads
GCS_BUCKET_NAME=satark-evidence

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
